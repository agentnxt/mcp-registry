{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "{{org_name}}",
  "url": "{{org_url}}",
  "logo": "{{logo_url}}",
  "description": "{{org_description}}",
  "sameAs": [
    "{{github_url}}",
    "{{twitter_url}}",
    "{{linkedin_url}}"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "technical support",
    "url": "{{support_url}}"
  },
  "makesOffer": [
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "SoftwareApplication",
        "name": "{{server_name}}",
        "applicationSubCategory": "MCP Server"
      }
    }
  ]
}
